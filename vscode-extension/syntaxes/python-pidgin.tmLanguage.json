{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Python Pidgin",
  "scopeName": "source.python-pidgin",
  "patterns": [
    {
      "name": "keyword.control.python-pidgin",
      "match": "\\b(check|unless|otherwise|as_far_say|per_person|inside|give_am)\\b"
    },
    {
      "name": "keyword.other.python-pidgin",
      "match": "\\b(na)\\b"
    },
    {
      "name": "keyword.operator.python-pidgin",
      "match": "\\b(small pass|big pass)\\b"
    },
    {
      "name": "support.function.builtin.python-pidgin",
      "match": "\\b(yarn)\\b"
    },
    {
      "name": "storage.type.function.python-pidgin",
      "match": "\\b(gist)\\b"
    },
    {
      "name": "constant.language.python-pidgin",
      "match": "\\b(real_talk|lie)\\b"
    },
    {
      "include": "source.python"
    }
  ]
}
